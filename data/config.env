# ==============================================================================
# ENTERPRISE QA SYSTEM - ENVIRONMENT CONFIGURATION (ASCII ONLY)
# ==============================================================================
# .venv\scripts\activate + uvicorn app.main:app --reload --port 8060

# Bypass platform checks for older OS environments --not used so far
#NODE_SKIP_PLATFORM_CHECK=1

# Web Server Infrastructure Settings
PORT=8060
HOST=127.0.0.1

# Automation Framework Global Configurations
# Local Sandbox App target URL (Port 8060 to avoid Oracle conflict)
TARGET_URL=http://127.0.0.1:8060

# Path to your local Google Chrome executable
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# NEW UPDATE: Headless toggle control (True for CI/CD Server, False for Local Debugging)
HEADLESS_MODE=False